generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id                 String           @id @default(cuid())
  slug               String           @unique
  name               String
  trendyolCategoryId Int?
  pazaramaCategoryId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deleted            Boolean          @default(false)
  deletedDate        DateTime?
  deletedUserId      String?
  parentId           String?
  Category           Category?        @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category     Category[]       @relation("CategoryToCategory")
  products           Product[]
  storefrontItems    StorefrontItem[]

  @@index([deleted])
  @@index([parentId])
  @@index([trendyolCategoryId])
  @@index([pazaramaCategoryId])
}

model Brand {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  trendyolBrandId Int?
  pazaramaBrandId String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deleted         Boolean   @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  products        Product[]

  @@index([deleted, isActive])
  @@index([trendyolBrandId])
  @@index([pazaramaBrandId])
}

model Supplier {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  taxNumber         String?
  email             String?
  phone             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deleted           Boolean            @default(false)
  deletedDate       DateTime?
  deletedUserId     String?
  paymentRecords    PaymentRecord[]
  primaryProducts   Product[]
  businessDocuments BusinessDocument[]

  @@index([deleted, isActive])
  @@index([taxNumber])
}

model CustomerAccount {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  email             String?
  phone             String?
  taxNumber         String?
  address           String?
  note              String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deleted           Boolean            @default(false)
  deletedDate       DateTime?
  deletedUserId     String?
  orders            Order[]
  businessDocuments BusinessDocument[]

  @@index([deleted, isActive])
  @@index([email])
  @@index([taxNumber])
}

model FinancialAccount {
  id                String               @id @default(cuid())
  name              String
  type              FinancialAccountType
  currency          String               @default("TRY")
  openingBalance    Decimal              @default(0) @db.Decimal(10, 2)
  isActive          Boolean              @default(true)
  note              String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deleted           Boolean              @default(false)
  deletedDate       DateTime?
  deletedUserId     String?
  transactions      CashTransaction[]
  collectionRecords CollectionRecord[]
  paymentRecords    PaymentRecord[]

  @@index([deleted, isActive])
  @@index([type, isActive])
}

model CashTransaction {
  id                String                    @id @default(cuid())
  accountId         String
  direction         CashTransactionDirection
  sourceType        CashTransactionSourceType @default(MANUAL)
  category          CashTransactionCategory?
  status            CashTransactionStatus     @default(RECORDED)
  amount            Decimal                   @db.Decimal(10, 2)
  currency          String                    @default("TRY")
  transactionAt     DateTime
  title             String
  note              String?
  sourceReferenceId String?
  counterpartyName  String?
  createdByUserId   String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deleted           Boolean                   @default(false)
  deletedDate       DateTime?
  deletedUserId     String?
  account           FinancialAccount          @relation(fields: [accountId], references: [id])

  @@index([accountId, transactionAt])
  @@index([status, transactionAt])
  @@index([deleted, transactionAt])
  @@index([sourceType, sourceReferenceId])
}

model ProductAttributeDefinition {
  id            String                         @id @default(cuid())
  slug          String                         @unique
  name          String
  trendyolAttributeId Int?
  displayType   ProductAttributeDisplayType    @default(TEXT)
  sortOrder     Int                            @default(0)
  isActive      Boolean                        @default(true)
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt
  deleted       Boolean                        @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  marketplaceValueMappings ProductAttributeValueMarketplaceMapping[]
  productLinks  ProductAttributeLink[]
  variantValues ProductVariantAttributeValue[]

  @@index([deleted, isActive, sortOrder])
  @@index([trendyolAttributeId])
}

model ProductAttributeValueMarketplaceMapping {
  id                         String                     @id @default(cuid())
  attributeDefinitionId      String
  channel                    IntegrationChannel
  localValue                 String
  externalAttributeValueId   Int?
  externalAttributeValueName String?
  customAttributeValue       String?
  isActive                   Boolean                    @default(true)
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  deleted                    Boolean                    @default(false)
  deletedDate                DateTime?
  deletedUserId              String?
  attributeDefinition        ProductAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id])

  @@unique([attributeDefinitionId, channel, localValue])
  @@index([channel, deleted, isActive])
  @@index([attributeDefinitionId, deleted])
}

model Product {
  id                           String                        @id @default(cuid())
  slug                         String                        @unique
  name                         String
  description                  String
  barcode                      String?
  unitType                     ProductUnitType               @default(PIECE)
  productType                  ProductType                   @default(PHYSICAL)
  price                        Decimal                       @db.Decimal(10, 2)
  purchasePrice                Decimal?                      @db.Decimal(10, 2)
  currency                     String                        @default("TRY")
  vatRate                      Int                           @default(20)
  stockTrackingEnabled         Boolean                       @default(true)
  imageUrl                     String
  imageUrls                    String[]                      @default([])
  categoryId                   String?
  brandId                      String?
  primarySupplierId            String?
  status                       ProductStatus                 @default(ACTIVE)
  salesEnabled                 Boolean                       @default(true)
  purchaseEnabled              Boolean                       @default(true)
  internalNote                 String?
  searchKeywords               String[]                      @default([])
  preferredSalesWarehouseId    String?
  preferredPurchaseWarehouseId String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  deleted                      Boolean                       @default(false)
  deletedDate                  DateTime?
  deletedUserId                String?
  sku                          String                        @unique
  compareAtPrice               Decimal?                      @db.Decimal(10, 2)
  stock                        Int                           @default(0)
  orderItems                   OrderItem[]
  brand                        Brand?                        @relation(fields: [brandId], references: [id])
  category                     Category?                     @relation(fields: [categoryId], references: [id])
  inventoryItem                InventoryItem?
  interaction                  ProductInteraction?
  primarySupplier              Supplier?                     @relation(fields: [primarySupplierId], references: [id])
  preferredSalesWarehouse      Warehouse?                    @relation("PreferredSalesWarehouseProducts", fields: [preferredSalesWarehouseId], references: [id])
  preferredPurchaseWarehouse   Warehouse?                    @relation("PreferredPurchaseWarehouseProducts", fields: [preferredPurchaseWarehouseId], references: [id])
  reviews                      ProductReview[]
  questions                    ProductQuestion[]
  attributeLinks               ProductAttributeLink[]
  variants                     ProductVariant[]
  storefrontItems              StorefrontItem[]
  externalStockEvents          ExternalStockEvent[]
  inventoryIntegrationMappings InventoryIntegrationMapping[]
  marketplaceOrderLines        MarketplaceOrderLine[]
  purchaseReceiptLines         PurchaseReceiptLine[]
  businessDocumentLines        BusinessDocumentLine[]
  inventoryHistoryEvents       InventoryHistoryEvent[]

  @@index([categoryId])
  @@index([brandId])
  @@index([primarySupplierId])
  @@index([barcode])
  @@index([deleted])
  @@index([status, salesEnabled])
  @@index([preferredSalesWarehouseId])
  @@index([preferredPurchaseWarehouseId])
  @@index([stock])
}

model ProductAttributeLink {
  id                    String                     @id @default(cuid())
  productId             String
  attributeDefinitionId String
  isVariantAxis         Boolean                    @default(false)
  sortOrder             Int                        @default(0)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  attributeDefinition   ProductAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id])
  product               Product                    @relation(fields: [productId], references: [id])

  @@unique([productId, attributeDefinitionId])
  @@index([attributeDefinitionId, isVariantAxis])
  @@index([productId, sortOrder])
}

model ProductVariant {
  id                     String                         @id @default(cuid())
  productId              String
  slug                   String                         @unique
  sku                    String                         @unique
  barcode                String?
  title                  String
  optionSummary          String
  priceOverride          Decimal?                       @db.Decimal(10, 2)
  purchasePriceOverride  Decimal?                       @db.Decimal(10, 2)
  compareAtPriceOverride Decimal?                       @db.Decimal(10, 2)
  imageUrl               String?
  imageUrls              String[]                       @default([])
  stockOverride          Int?
  salesEnabled           Boolean                        @default(true)
  isDefault              Boolean                        @default(false)
  sortOrder              Int                            @default(0)
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  deleted                Boolean                        @default(false)
  deletedDate            DateTime?
  deletedUserId          String?
  product                Product                        @relation(fields: [productId], references: [id])
  attributeValues        ProductVariantAttributeValue[]
  inventoryItem          InventoryItem?
  orderItems             OrderItem[]
  marketplaceOrderLines  MarketplaceOrderLine[]
  purchaseReceiptLines   PurchaseReceiptLine[]
  businessDocumentLines  BusinessDocumentLine[]

  @@index([productId, deleted, salesEnabled, sortOrder])
  @@index([barcode])
}

model ProductVariantAttributeValue {
  id                    String                     @id @default(cuid())
  productVariantId      String
  attributeDefinitionId String
  value                 String
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  attributeDefinition   ProductAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id])
  productVariant        ProductVariant             @relation(fields: [productVariantId], references: [id])

  @@unique([productVariantId, attributeDefinitionId])
  @@index([attributeDefinitionId, value])
}

model ProductReview {
  id               String    @id @default(cuid())
  productId        String
  authorUserId     String? // Application-level, not a foreign key
  authorName       String
  rating           Int
  title            String
  comment          String
  verifiedPurchase Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deleted          Boolean   @default(false)
  deletedDate      DateTime?
  deletedUserId    String?
  product          Product   @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([deleted])
  @@index([authorUserId])
  @@index([productId, authorUserId])
}

model ProductQuestion {
  id            String    @id @default(cuid())
  productId     String
  question      String
  askedBy       String
  answer        String?
  answeredBy    String?
  answeredAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deleted       Boolean   @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  product       Product   @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([deleted])
}

model ProductInteraction {
  id           String    @id @default(cuid())
  productId    String    @unique
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  product      Product   @relation(fields: [productId], references: [id])

  @@index([viewCount])
}

model Promotion {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  type          PromotionType
  value         Decimal       @db.Decimal(10, 2)
  currency      String        @default("TRY")
  minSubtotal   Decimal?      @db.Decimal(10, 2)
  maxDiscount   Decimal?      @db.Decimal(10, 2)
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int           @default(0)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deleted       Boolean       @default(false)
  deletedDate   DateTime?
  deletedUserId String?

  @@index([active, deleted])
  @@index([startsAt, endsAt])
}

model Order {
  id                   String                      @id @default(cuid())
  orderNumber          String                      @unique
  status               OrderStatus                 @default(CONFIRMED)
  subtotal             Decimal                     @db.Decimal(10, 2)
  currency             String                      @default("TRY")
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  deleted              Boolean                     @default(false)
  deletedDate          DateTime?
  deletedUserId        String?
  customerAccountId    String?
  discountTotal        Decimal                     @default(0) @db.Decimal(10, 2)
  paymentStatus        PaymentStatus               @default(PENDING)
  promotionCode        String?
  total                Decimal                     @default(0) @db.Decimal(10, 2)
  items                OrderItem[]
  inventoryMovements   InventoryMovement[]
  paymentStatusHistory OrderPaymentStatusHistory[]
  collectionRecords    CollectionRecord[]
  stockReservations    StockReservation[]
  statusHistory        OrderStatusHistory[]
  businessDocuments    BusinessDocument[]
  marketplacePackages  MarketplaceOrderPackage[]
  customerAccount      CustomerAccount?            @relation(fields: [customerAccountId], references: [id])

  @@index([deleted])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([status])
  @@index([customerAccountId])
}

model OrderItem {
  id                          String          @id @default(cuid())
  orderId                     String
  productId                   String?
  productVariantId            String?
  productSlug                 String
  productSku                  String
  productVariantSlug          String?
  productVariantSku           String?
  productVariantTitle         String?
  productVariantOptionSummary String?
  productName                 String
  productImageUrl             String
  quantity                    Int
  unitPrice                   Decimal         @db.Decimal(10, 2)
  compareAtPrice              Decimal?        @db.Decimal(10, 2)
  lineTotal                   Decimal         @db.Decimal(10, 2)
  currency                    String
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
  deleted                     Boolean         @default(false)
  deletedDate                 DateTime?
  deletedUserId               String?
  order                       Order           @relation(fields: [orderId], references: [id])
  product                     Product?        @relation(fields: [productId], references: [id])
  productVariant              ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
  @@index([deleted])
}

model OrderStatusHistory {
  id              String                  @id @default(cuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  source          OrderStatusChangeSource @default(SYSTEM)
  changedByUserId String?
  note            String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deleted         Boolean                 @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  order           Order                   @relation(fields: [orderId], references: [id])

  @@index([deleted])
  @@index([orderId, createdAt])
}

model OrderPaymentStatusHistory {
  id              String                    @id @default(cuid())
  orderId         String
  fromStatus      PaymentStatus?
  toStatus        PaymentStatus
  source          PaymentStatusChangeSource @default(SYSTEM)
  changedByUserId String?
  note            String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deleted         Boolean                   @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  order           Order                     @relation(fields: [orderId], references: [id])

  @@index([deleted])
  @@index([orderId, createdAt])
}

model CollectionRecord {
  id                 String                 @id @default(cuid())
  orderId            String
  financialAccountId String?
  amount             Decimal                @db.Decimal(10, 2)
  currency           String                 @default("TRY")
  status             CollectionRecordStatus @default(RECORDED)
  collectedAt        DateTime
  note               String?
  recordedByUserId   String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deleted            Boolean                @default(false)
  deletedDate        DateTime?
  deletedUserId      String?
  order              Order                  @relation(fields: [orderId], references: [id])
  financialAccount   FinancialAccount?      @relation(fields: [financialAccountId], references: [id])

  @@index([orderId, collectedAt])
  @@index([financialAccountId, collectedAt])
  @@index([status, collectedAt])
  @@index([deleted, collectedAt])
}

model PaymentRecord {
  id                 String              @id @default(cuid())
  supplierId         String
  financialAccountId String?
  amount             Decimal             @db.Decimal(10, 2)
  currency           String              @default("TRY")
  status             PaymentRecordStatus @default(RECORDED)
  paidAt             DateTime
  note               String?
  recordedByUserId   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deleted            Boolean             @default(false)
  deletedDate        DateTime?
  deletedUserId      String?
  supplier           Supplier            @relation(fields: [supplierId], references: [id])
  financialAccount   FinancialAccount?   @relation(fields: [financialAccountId], references: [id])

  @@index([supplierId, paidAt])
  @@index([financialAccountId, paidAt])
  @@index([status, paidAt])
  @@index([deleted, paidAt])
}

model BusinessDocument {
  id                     String                     @id @default(cuid())
  documentNumber         String                     @unique
  documentType           BusinessDocumentType
  status                 BusinessDocumentStatus     @default(DRAFT)
  issueDate              DateTime
  currency               String                     @default("TRY")
  totalAmount            Decimal?                   @db.Decimal(10, 2)
  externalReference      String?
  externalSystemStatus   BusinessDocumentSyncStatus @default(NOT_SENT)
  providerConfigId       String?
  counterpartyName       String
  counterpartyTaxNumber  String?
  counterpartyTaxOffice  String?
  counterpartyEmail      String?
  counterpartyAddress    String?
  note                   String?
  supplierId             String?
  customerAccountId      String?
  orderId                String?
  inventoryTransactionId String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  deleted                Boolean                    @default(false)
  deletedDate            DateTime?
  deletedUserId          String?
  dispatches             BusinessDocumentDispatch[]
  lines                  BusinessDocumentLine[]
  supplier               Supplier?                  @relation(fields: [supplierId], references: [id])
  customerAccount        CustomerAccount?           @relation(fields: [customerAccountId], references: [id])
  order                  Order?                     @relation(fields: [orderId], references: [id])
  inventoryTransaction   InventoryTransaction?      @relation(fields: [inventoryTransactionId], references: [id])
  providerConfig         DocumentProviderConfig?    @relation(fields: [providerConfigId], references: [id])

  @@index([documentType, issueDate])
  @@index([status, issueDate])
  @@index([providerConfigId])
  @@index([supplierId])
  @@index([customerAccountId])
  @@index([orderId])
  @@index([inventoryTransactionId])
  @@index([deleted, issueDate])
}

model BusinessDocumentLine {
  id                  String           @id @default(cuid())
  businessDocumentId  String
  productId           String?
  productVariantId    String?
  productSku          String
  productVariantSku   String?
  productName         String
  productVariantTitle String?
  quantity            Int
  unitPrice           Decimal?         @db.Decimal(10, 2)
  lineTotal           Decimal?         @db.Decimal(10, 2)
  currency            String           @default("TRY")
  note                String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  businessDocument    BusinessDocument @relation(fields: [businessDocumentId], references: [id])
  product             Product?         @relation(fields: [productId], references: [id])
  productVariant      ProductVariant?  @relation(fields: [productVariantId], references: [id])

  @@index([businessDocumentId])
  @@index([productId])
  @@index([productVariantId])
}

model BusinessDocumentDispatch {
  id                 String                     @id @default(cuid())
  businessDocumentId String
  integrationJobId   String?
  channel            IntegrationChannel
  providerKey        String
  status             BusinessDocumentSyncStatus @default(QUEUED)
  externalReference  String?
  requestPayload     Json?
  responsePayload    Json?
  errorMessage       String?
  queuedAt           DateTime                   @default(now())
  dispatchedAt       DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  businessDocument   BusinessDocument           @relation(fields: [businessDocumentId], references: [id])

  @@index([businessDocumentId, createdAt])
  @@index([integrationJobId])
  @@index([channel, status])
}

model DocumentProviderConfig {
  id                 String             @id @default(cuid())
  providerCode       String             @unique
  channel            IntegrationChannel
  displayName        String
  endpointUrl        String?
  senderLabel        String?
  senderVkn          String?
  username           String?
  secretKey          String?
  companyName        String?
  webhookSecret      String?
  supportsStatusSync Boolean            @default(true)
  isActive           Boolean            @default(true)
  isDefault          Boolean            @default(false)
  note               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deleted            Boolean            @default(false)
  deletedDate        DateTime?
  deletedUserId      String?
  documents          BusinessDocument[]

  @@index([channel, isActive, deleted])
  @@index([isDefault, deleted])
}

model Warehouse {
  id                            String                        @id @default(cuid())
  code                          String                        @unique
  name                          String
  description                   String?
  address                       String?
  contactName                   String?
  contactPhone                  String?
  priority                      Int                           @default(100)
  isActive                      Boolean                       @default(true)
  isDefault                     Boolean                       @default(false)
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  inventoryLevels               InventoryLevel[]
  inventoryAlerts               InventoryAlert[]
  incomingInventoryTransactions InventoryTransactionLine[]    @relation("InventoryTransactionLineToWarehouse")
  inventoryMovements            InventoryMovement[]
  outgoingInventoryTransactions InventoryTransactionLine[]    @relation("InventoryTransactionLineFromWarehouse")
  stockCounts                   StockCount[]
  stockCountLines               StockCountLine[]
  preferredPurchaseProducts     Product[]                     @relation("PreferredPurchaseWarehouseProducts")
  preferredSalesProducts        Product[]                     @relation("PreferredSalesWarehouseProducts")
  stockReservations             StockReservation[]
  externalStockEvents           ExternalStockEvent[]
  inventoryIntegrationMappings  InventoryIntegrationMapping[]
  purchaseReceipts              PurchaseReceipt[]
  inventoryHistoryEvents        InventoryHistoryEvent[]

  @@index([isActive, isDefault])
  @@index([priority])
}

model InventoryItem {
  id                        String                     @id @default(cuid())
  productId                 String?
  productVariantId          String?                    @unique
  skuSnapshot               String
  costingMethod             InventoryCostingMethod     @default(AVERAGE_COST)
  averageUnitCost           Decimal?                   @db.Decimal(10, 2)
  lastPurchaseUnitCost      Decimal?                   @db.Decimal(10, 2)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  inventoryAlerts           InventoryAlert[]
  inventoryTransactionLines InventoryTransactionLine[]
  product                   Product?                   @relation(fields: [productId], references: [id])
  productVariant            ProductVariant?            @relation(fields: [productVariantId], references: [id])
  inventoryLevels           InventoryLevel[]
  inventoryMovements        InventoryMovement[]
  stockCountLines           StockCountLine[]
  stockReservations         StockReservation[]

  @@unique([productId])
  @@index([productId])
  @@index([productVariantId])
}

model InventoryLevel {
  id              String        @id @default(cuid())
  inventoryItemId String
  warehouseId     String
  onHand          Int           @default(0)
  reserved        Int           @default(0)
  reorderPoint    Int           @default(0)
  safetyStock     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([inventoryItemId, warehouseId])
  @@index([warehouseId])
  @@index([onHand, reserved])
}

model StockReservation {
  id                 String                 @id @default(cuid())
  inventoryItemId    String
  warehouseId        String
  orderId            String?
  reference          String?
  quantity           Int
  status             StockReservationStatus @default(ACTIVE)
  expiresAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  inventoryItem      InventoryItem          @relation(fields: [inventoryItemId], references: [id])
  warehouse          Warehouse              @relation(fields: [warehouseId], references: [id])
  order              Order?                 @relation(fields: [orderId], references: [id])
  inventoryMovements InventoryMovement[]

  @@index([inventoryItemId, status])
  @@index([warehouseId, status])
  @@index([orderId])
  @@index([expiresAt])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  inventoryItemId String
  warehouseId     String
  orderId         String?
  reservationId   String?
  transactionId   String?
  type            InventoryMovementType
  quantity        Int
  note            String?
  metadata        Json?
  createdAt       DateTime              @default(now())
  createdAlerts   InventoryAlert[]      @relation("InventoryAlertCreatedMovement")
  resolvedAlerts  InventoryAlert[]      @relation("InventoryAlertResolvedMovement")
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  transaction     InventoryTransaction? @relation(fields: [transactionId], references: [id])
  warehouse       Warehouse             @relation(fields: [warehouseId], references: [id])
  order           Order?                @relation(fields: [orderId], references: [id])
  reservation     StockReservation?     @relation(fields: [reservationId], references: [id])

  @@index([inventoryItemId, createdAt])
  @@index([transactionId])
  @@index([warehouseId, createdAt])
  @@index([orderId])
  @@index([reservationId])
  @@index([type, createdAt])
}

model StockCount {
  id          String           @id @default(cuid())
  countNumber String           @unique
  warehouseId String?
  status      StockCountStatus @default(DRAFT)
  countedAt   DateTime
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  warehouse   Warehouse?       @relation(fields: [warehouseId], references: [id])
  lines       StockCountLine[]

  @@index([status, countedAt])
  @@index([warehouseId])
}

model StockCountLine {
  id              String        @id @default(cuid())
  stockCountId    String
  inventoryItemId String
  warehouseId     String
  systemOnHand    Int
  countedOnHand   Int?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  stockCount      StockCount    @relation(fields: [stockCountId], references: [id])
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([stockCountId, inventoryItemId, warehouseId])
  @@index([warehouseId])
  @@index([inventoryItemId])
}

model InventoryAlert {
  id                 String               @id @default(cuid())
  inventoryItemId    String
  warehouseId        String
  type               InventoryAlertType
  status             InventoryAlertStatus @default(ACTIVE)
  message            String
  createdMovementId  String?
  resolvedMovementId String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  inventoryItem      InventoryItem        @relation(fields: [inventoryItemId], references: [id])
  warehouse          Warehouse            @relation(fields: [warehouseId], references: [id])
  createdMovement    InventoryMovement?   @relation("InventoryAlertCreatedMovement", fields: [createdMovementId], references: [id])
  resolvedMovement   InventoryMovement?   @relation("InventoryAlertResolvedMovement", fields: [resolvedMovementId], references: [id])

  @@index([status, type, createdAt])
  @@index([warehouseId])
  @@index([inventoryItemId])
}

model InventoryTransaction {
  id                   String                     @id @default(cuid())
  transactionNumber    String                     @unique
  type                 InventoryTransactionType
  reference            String?
  sourceDocumentType   String?
  sourceDocumentId     String?
  sourceDocumentNumber String?
  sourceDocumentUrl    String?
  sourceDocumentDate   DateTime?
  externalReference    String?
  externalSystemStatus String?
  counterpartyName     String?
  note                 String?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  lines                InventoryTransactionLine[]
  movements            InventoryMovement[]
  purchaseReceipt      PurchaseReceipt?
  businessDocuments    BusinessDocument[]

  @@index([type, createdAt])
  @@index([sourceDocumentType, sourceDocumentNumber])
}

model PurchaseReceipt {
  id                String                @id @default(cuid())
  receiptNumber     String                @unique
  supplierName      String
  receiptDate       DateTime
  externalReference String?
  note              String?
  warehouseId       String
  transactionId     String                @unique
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  warehouse         Warehouse             @relation(fields: [warehouseId], references: [id])
  transaction       InventoryTransaction  @relation(fields: [transactionId], references: [id])
  lines             PurchaseReceiptLine[]

  @@index([warehouseId, receiptDate])
  @@index([supplierName, receiptDate])
}

model PurchaseReceiptLine {
  id                String          @id @default(cuid())
  purchaseReceiptId String
  productId         String
  productVariantId  String?
  quantity          Int
  unitCost          Decimal?        @db.Decimal(10, 2)
  lineTotal         Decimal?        @db.Decimal(10, 2)
  note              String?
  createdAt         DateTime        @default(now())
  purchaseReceipt   PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([purchaseReceiptId])
  @@index([productId])
  @@index([productVariantId])
}

model InventoryTransactionLine {
  id                   String               @id @default(cuid())
  transactionId        String
  inventoryItemId      String
  fromWarehouseId      String?
  toWarehouseId        String?
  quantity             Int
  note                 String?
  createdAt            DateTime             @default(now())
  inventoryItem        InventoryItem        @relation(fields: [inventoryItemId], references: [id])
  inventoryTransaction InventoryTransaction @relation(fields: [transactionId], references: [id])
  fromWarehouse        Warehouse?           @relation("InventoryTransactionLineFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse          Warehouse?           @relation("InventoryTransactionLineToWarehouse", fields: [toWarehouseId], references: [id])

  @@index([transactionId])
  @@index([inventoryItemId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model IntegrationSyncJob {
  id             String                 @id @default(cuid())
  idempotencyKey String                 @unique
  channel        IntegrationChannel
  jobType        IntegrationJobType
  entityType     IntegrationEntityType
  entityId       String
  payload        Json?
  status         IntegrationJobStatus   @default(PENDING)
  attemptCount   Int                    @default(0)
  maxAttempts    Int                    @default(3)
  nextAttemptAt  DateTime               @default(now())
  lastAttemptAt  DateTime?
  processedAt    DateTime?
  externalReference String?
  responsePayload Json?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deleted        Boolean                @default(false)
  deletedDate    DateTime?
  deletedUserId  String?
  deadLetter     IntegrationDeadLetter?

  @@index([status, nextAttemptAt])
  @@index([deleted])
  @@index([channel, jobType])
  @@index([entityType, entityId])
}

model IntegrationDeadLetter {
  id               String                @id @default(cuid())
  jobId            String                @unique
  channel          IntegrationChannel
  jobType          IntegrationJobType
  entityType       IntegrationEntityType
  entityId         String
  payload          Json?
  lastError        String
  attemptCount     Int
  maxAttempts      Int
  resolved         Boolean               @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deleted          Boolean               @default(false)
  deletedDate      DateTime?
  deletedUserId    String?
  job              IntegrationSyncJob    @relation(fields: [jobId], references: [id])

  @@index([resolved, deleted])
  @@index([channel, jobType])
  @@index([entityType, entityId])
}

model MarketplaceIntegrationConfig {
  id                   String                    @id @default(cuid())
  channel              IntegrationChannel
  displayName          String
  sellerId             String
  apiKeyEncrypted      String
  apiSecretEncrypted   String
  serviceTokenEncrypted String?
  userAgent            String
  storeFrontCode       String?
  endpointUrl          String?
  trendyolCargoCompanyId Int?
  trendyolShipmentAddressId Int?
  trendyolReturningAddressId Int?
  trendyolOrigin       String?
  trendyolDimensionalWeight Decimal?                  @db.Decimal(10, 2)
  environment          MarketplaceEnvironment    @default(PRODUCTION)
  syncWindowMinutes    Int                       @default(60)
  lastSuccessfulSyncAt DateTime?
  lastCursorAt         DateTime?
  isActive             Boolean                   @default(true)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  deleted              Boolean                   @default(false)
  deletedDate          DateTime?
  deletedUserId        String?
  packages             MarketplaceOrderPackage[]

  @@unique([channel, sellerId, deleted])
  @@index([channel, isActive, deleted])
}

model MarketplaceOrderPackage {
  id                  String                         @id @default(cuid())
  configId            String
  channel             IntegrationChannel
  externalPackageId   String
  externalOrderNumber String
  packageStatus       String
  importStatus        MarketplacePackageImportStatus @default(RECEIVED)
  orderDate           DateTime?
  lastModifiedDate    DateTime?
  customerName        String?
  customerEmail       String?
  shipmentAddress     Json?
  invoiceAddress      Json?
  cargoProviderName   String?
  cargoTrackingNumber String?
  rawPayload          Json?
  matchedOrderId      String?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  deleted             Boolean                        @default(false)
  deletedDate         DateTime?
  deletedUserId       String?
  config              MarketplaceIntegrationConfig   @relation(fields: [configId], references: [id])
  matchedOrder        Order?                         @relation(fields: [matchedOrderId], references: [id])
  lines               MarketplaceOrderLine[]

  @@unique([channel, configId, externalPackageId])
  @@index([configId, deleted])
  @@index([channel, packageStatus, deleted])
  @@index([externalOrderNumber])
  @@index([matchedOrderId])
}

model MarketplaceOrderLine {
  id               String                          @id @default(cuid())
  packageId        String
  externalLineId   String
  merchantSku      String?
  barcode          String?
  productName      String
  quantity         Int
  unitPrice        Decimal?                        @db.Decimal(10, 2)
  currency         String                          @default("TRY")
  matchStatus      MarketplaceOrderLineMatchStatus @default(UNMATCHED)
  productId        String?
  productVariantId String?
  rawPayload       Json?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  deleted          Boolean                         @default(false)
  deletedDate      DateTime?
  deletedUserId    String?
  package          MarketplaceOrderPackage         @relation(fields: [packageId], references: [id])
  product          Product?                        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?                 @relation(fields: [productVariantId], references: [id])

  @@unique([packageId, externalLineId])
  @@index([packageId, deleted])
  @@index([merchantSku])
  @@index([barcode])
  @@index([productId])
  @@index([productVariantId])
}

model InventoryIntegrationMapping {
  id                    String               @id @default(cuid())
  channel               IntegrationChannel
  externalProductId     String?
  externalSku           String?
  externalWarehouseCode String?
  productId             String
  warehouseId           String?
  allowInboundUpdates   Boolean              @default(false)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deleted               Boolean              @default(false)
  deletedDate           DateTime?
  deletedUserId         String?
  product               Product              @relation(fields: [productId], references: [id])
  warehouse             Warehouse?           @relation(fields: [warehouseId], references: [id])
  externalStockEvents   ExternalStockEvent[]

  @@unique([channel, externalProductId, externalWarehouseCode])
  @@unique([channel, externalSku, externalWarehouseCode])
  @@index([channel, deleted])
  @@index([productId, deleted])
  @@index([warehouseId, deleted])
}

model ExternalStockEvent {
  id                    String                       @id @default(cuid())
  channel               IntegrationChannel
  eventKey              String                       @unique
  eventType             ExternalStockEventType
  direction             ExternalStockEventDirection  @default(INBOUND)
  status                ExternalStockEventStatus     @default(RECEIVED)
  externalProductId     String?
  externalSku           String?
  externalWarehouseCode String?
  mappingId             String?
  productId             String?
  warehouseId           String?
  quantity              Int
  reference             String?
  note                  String?
  payload               Json?
  appliedOnHand         Int?
  appliedAvailable      Int?
  errorMessage          String?
  processedAt           DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  mapping               InventoryIntegrationMapping? @relation(fields: [mappingId], references: [id])
  product               Product?                     @relation(fields: [productId], references: [id])
  warehouse             Warehouse?                   @relation(fields: [warehouseId], references: [id])

  @@index([channel, status, createdAt])
  @@index([mappingId])
  @@index([productId, warehouseId])
}

model StorefrontItem {
  id            String                @id @default(cuid())
  section       StorefrontSection
  variant       String
  titleTr       String
  titleEn       String
  descriptionTr String
  descriptionEn String
  sortOrder     Int
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deleted       Boolean               @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  categoryId    String?
  productId     String?
  targetType    StorefrontTargetType?
  category      Category?             @relation(fields: [categoryId], references: [id])
  product       Product?              @relation(fields: [productId], references: [id])

  @@index([deleted])
  @@index([categoryId])
  @@index([productId])
  @@index([section, deleted, sortOrder])
  @@index([startsAt, endsAt])
  @@index([targetType])
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  name                     String
  passwordHash             String
  role                     UserRole                 @default(EDITOR)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  deleted                  Boolean                  @default(false)
  deletedDate              DateTime?
  deletedUserId            String?
  notifications            UserNotification[]
  socialAccounts           SocialAccount[]
  inventoryPreference      UserInventoryPreference?
  inventoryExportHistories InventoryExportHistory[]

  @@index([deleted])
}

model InventoryExportHistory {
  id                 String   @id @default(cuid())
  actorUserId        String?
  total              Int      @default(0)
  search             String?
  stockStatusFilter  String?
  reservationFilter  String?
  warehouseFilter    String?
  movementTypeFilter String?
  createdAt          DateTime @default(now())
  actor              User?    @relation(fields: [actorUserId], references: [id])

  @@index([createdAt])
  @@index([actorUserId, createdAt])
}

model UserInventoryPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  compactInventoryList Boolean  @default(false)
  visibleColumns       Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id])
}

model SocialAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  providerEmail     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model UserNotification {
  id        String                  @id @default(cuid())
  userId    String
  type      UserNotificationType
  channel   UserNotificationChannel
  title     String
  message   String
  linkUrl   String?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime                @default(now())
  user      User                    @relation(fields: [userId], references: [id])

  @@index([userId, channel, createdAt])
  @@index([userId, channel, readAt])
  @@index([channel, sentAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String?
  action      String
  actorUserId String?
  summary     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([actorUserId, createdAt])
}

model InventoryHistoryEvent {
  id                String                     @id @default(cuid())
  eventType         InventoryHistoryEventType
  entityType        InventoryHistoryEntityType
  entityId          String?
  productId         String?
  warehouseId       String?
  transactionId     String?
  stockCountId      String?
  purchaseReceiptId String?
  actorUserId       String?
  title             String
  summary           String
  metadata          Json?
  createdAt         DateTime                   @default(now())
  product           Product?                   @relation(fields: [productId], references: [id])
  warehouse         Warehouse?                 @relation(fields: [warehouseId], references: [id])

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([entityType, createdAt])
  @@index([productId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([actorUserId, createdAt])
}

