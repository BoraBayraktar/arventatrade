generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deleted         Boolean          @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  parentId        String?
  Category        Category?        @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category  Category[]       @relation("CategoryToCategory")
  products        Product[]
  storefrontItems StorefrontItem[]

  @@index([deleted])
  @@index([parentId])
}

model Product {
  id              String              @id @default(cuid())
  slug            String              @unique
  name            String
  description     String
  price           Decimal             @db.Decimal(10, 2)
  currency        String              @default("TRY")
  imageUrl        String
  imageUrls       String[]            @default([])
  categoryId      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deleted         Boolean             @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  sku             String              @unique
  compareAtPrice  Decimal?            @db.Decimal(10, 2)
  stock           Int                 @default(0)
  orderItems      OrderItem[]
  category        Category?           @relation(fields: [categoryId], references: [id])
  interaction     ProductInteraction?
  reviews         ProductReview[]
  questions       ProductQuestion[]
  storefrontItems StorefrontItem[]

  @@index([categoryId])
  @@index([deleted])
  @@index([stock])
}

model ProductReview {
  id               String    @id @default(cuid())
  productId        String
  authorUserId     String? // Application-level, not a foreign key
  authorName       String
  rating           Int
  title            String
  comment          String
  verifiedPurchase Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deleted          Boolean   @default(false)
  deletedDate      DateTime?
  deletedUserId    String?
  product          Product   @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([deleted])
  @@index([authorUserId])
  @@index([productId, authorUserId])
}

model ProductQuestion {
  id            String    @id @default(cuid())
  productId     String
  question      String
  askedBy       String
  answer        String?
  answeredBy    String?
  answeredAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deleted       Boolean   @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  product       Product   @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([deleted])
}

model ProductInteraction {
  id           String    @id @default(cuid())
  productId    String    @unique
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  product      Product   @relation(fields: [productId], references: [id])

  @@index([viewCount])
}

model Promotion {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  type          PromotionType
  value         Decimal       @db.Decimal(10, 2)
  currency      String        @default("TRY")
  minSubtotal   Decimal?      @db.Decimal(10, 2)
  maxDiscount   Decimal?      @db.Decimal(10, 2)
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int           @default(0)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deleted       Boolean       @default(false)
  deletedDate   DateTime?
  deletedUserId String?

  @@index([active, deleted])
  @@index([startsAt, endsAt])
}

model Order {
  id                   String                      @id @default(cuid())
  orderNumber          String                      @unique
  status               OrderStatus                 @default(CONFIRMED)
  subtotal             Decimal                     @db.Decimal(10, 2)
  currency             String                      @default("TRY")
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  deleted              Boolean                     @default(false)
  deletedDate          DateTime?
  deletedUserId        String?
  discountTotal        Decimal                     @default(0) @db.Decimal(10, 2)
  paymentStatus        PaymentStatus               @default(PENDING)
  promotionCode        String?
  total                Decimal                     @default(0) @db.Decimal(10, 2)
  items                OrderItem[]
  paymentStatusHistory OrderPaymentStatusHistory[]
  statusHistory        OrderStatusHistory[]

  @@index([deleted])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([status])
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String
  productId       String?
  productSlug     String
  productSku      String
  productName     String
  productImageUrl String
  quantity        Int
  unitPrice       Decimal   @db.Decimal(10, 2)
  compareAtPrice  Decimal?  @db.Decimal(10, 2)
  lineTotal       Decimal   @db.Decimal(10, 2)
  currency        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deleted         Boolean   @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  order           Order     @relation(fields: [orderId], references: [id])
  product         Product?  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([deleted])
}

model OrderStatusHistory {
  id              String                  @id @default(cuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  source          OrderStatusChangeSource @default(SYSTEM)
  changedByUserId String?
  note            String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deleted         Boolean                 @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  order           Order                   @relation(fields: [orderId], references: [id])

  @@index([deleted])
  @@index([orderId, createdAt])
}

model OrderPaymentStatusHistory {
  id              String                    @id @default(cuid())
  orderId         String
  fromStatus      PaymentStatus?
  toStatus        PaymentStatus
  source          PaymentStatusChangeSource @default(SYSTEM)
  changedByUserId String?
  note            String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deleted         Boolean                   @default(false)
  deletedDate     DateTime?
  deletedUserId   String?
  order           Order                     @relation(fields: [orderId], references: [id])

  @@index([deleted])
  @@index([orderId, createdAt])
}

model IntegrationSyncJob {
  id             String                 @id @default(cuid())
  idempotencyKey String                 @unique
  channel        IntegrationChannel
  jobType        IntegrationJobType
  entityType     IntegrationEntityType
  entityId       String
  payload        Json?
  status         IntegrationJobStatus   @default(PENDING)
  attemptCount   Int                    @default(0)
  maxAttempts    Int                    @default(3)
  nextAttemptAt  DateTime               @default(now())
  lastAttemptAt  DateTime?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  deleted        Boolean                @default(false)
  deletedDate    DateTime?
  deletedUserId  String?
  deadLetter     IntegrationDeadLetter?

  @@index([status, nextAttemptAt])
  @@index([deleted])
  @@index([channel, jobType])
  @@index([entityType, entityId])
}

model IntegrationDeadLetter {
  id               String                @id @default(cuid())
  jobId            String                @unique
  channel          IntegrationChannel
  jobType          IntegrationJobType
  entityType       IntegrationEntityType
  entityId         String
  payload          Json?
  lastError        String
  attemptCount     Int
  maxAttempts      Int
  resolved         Boolean               @default(false)
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deleted          Boolean               @default(false)
  deletedDate      DateTime?
  deletedUserId    String?
  job              IntegrationSyncJob    @relation(fields: [jobId], references: [id])

  @@index([resolved, deleted])
  @@index([channel, jobType])
  @@index([entityType, entityId])
}

model StorefrontItem {
  id            String                @id @default(cuid())
  section       StorefrontSection
  variant       String
  titleTr       String
  titleEn       String
  descriptionTr String
  descriptionEn String
  sortOrder     Int
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deleted       Boolean               @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  categoryId    String?
  productId     String?
  targetType    StorefrontTargetType?
  category      Category?             @relation(fields: [categoryId], references: [id])
  product       Product?              @relation(fields: [productId], references: [id])

  @@index([deleted])
  @@index([categoryId])
  @@index([productId])
  @@index([section, deleted, sortOrder])
  @@index([startsAt, endsAt])
  @@index([targetType])
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String
  passwordHash  String
  role          UserRole           @default(EDITOR)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deleted       Boolean            @default(false)
  deletedDate   DateTime?
  deletedUserId String?
  notifications UserNotification[]

  @@index([deleted])
}

model UserNotification {
  id        String                  @id @default(cuid())
  userId    String
  type      UserNotificationType
  channel   UserNotificationChannel
  title     String
  message   String
  linkUrl   String?
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime                @default(now())
  user      User                    @relation(fields: [userId], references: [id])

  @@index([userId, channel, createdAt])
  @@index([userId, channel, readAt])
  @@index([channel, sentAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String?
  action      String
  actorUserId String?
  summary     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([actorUserId, createdAt])
}

enum UserRole {
  ADMIN
  EDITOR
  CUSTOMER
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum IntegrationChannel {
  TRENDYOL
  N11
}

enum IntegrationJobType {
  PRODUCT_SYNC
  PRICE_SYNC
  STOCK_SYNC
}

enum IntegrationEntityType {
  PRODUCT
}

enum IntegrationJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  DEAD_LETTER
}

enum StorefrontSection {
  HOME_CAMPAIGN
  HOME_FEATURE
}

enum StorefrontTargetType {
  PRODUCT
  CATEGORY
}

enum OrderStatus {
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum OrderStatusChangeSource {
  SYSTEM
  ADMIN
}

enum PaymentStatusChangeSource {
  SYSTEM
  ADMIN
}

enum UserNotificationType {
  PRODUCT_QUESTION_CREATED
}

enum UserNotificationChannel {
  IN_APP
  EMAIL
}
